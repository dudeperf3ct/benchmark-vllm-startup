project_id      = "your-gcp-project-id"
region          = "europe-west4"
zone            = "europe-west4-a"
cluster_name    = "benchmark-cold-start"
gcs_bucket_name = "your-globally-unique-benchmark-bucket"

# GPU defaults
gpu_machine_type = "g2-standard-8"
gpu_type         = "nvidia-l4"
gpu_count        = 1
gpu_node_count   = 1

# Run blocks:
# - set false for V1 and V2
# - set true for V3 and V4
gpu_enable_image_streaming = false
